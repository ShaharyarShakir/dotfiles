{
  "layer": "top",
  "position": "top",
  "mod": "dock",
  "exclusive": true,
  "passthrough": false,
  "gtk-layer-shell": true,
  "height": 32,
  "width": "1280",
  "margin-right": 5,
  "margin-left": 5,

  "modules-left": [
    "custom/rofi",
    "clock"
  ],

  "modules-center": [
    "custom/notifications",
    "hyprland/workspaces"
  ],

  "modules-right": [
    "tray",
    "battery",
    "custom/volume",
    "bluetooth",
    "pulseaudio#microphone",
    "backlight",
    "network",
    "custom/power"
  ],

  "custom/rofi": {
    "format": "пЊѓ",
    "on-click": "rofi -theme ~/.config/rofi/theme/onedark_mini.rasi -show drun",
    "tooltip": false
  },

  "clock": {
    "format": "пЂ— {:%I:%M %p}",
    "tooltip": true,
    "tooltip-format": "{:%A, %d %B %Y}",
    "interval": 60
  },

  "custom/notifications": {
    "format": "{}",
    "return-type": "json",
    "interval": 1,
    "exec": "~/.config/waybar/scripts/swaync_status.sh",
    "on-click": "swaync-client -t",
    "on-click-right": "swaync-client -C",
    "on-click-middle": "swaync-client -d",
    "tooltip": false
  },

  "hyprland/workspaces": {
    "on-click": "activate",
    "disable-scroll": true,
    "all-outputs": true,
    "show-special": false,
    "format": "{id}",
    "format-icons": {
      "active": "{id}",
      "default": ""
    }
  },

  "custom/volume": {
    "format": "{}",
    "exec": "~/.config/waybar/scripts/volume.sh",
    "interval": 1,
    "return-type": "text",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-scroll-up": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%-",
    "tooltip": true
  },
"bluetooth": {
  "format": "пЉ”",
  "format-disabled": "у°‚І",
  "format-connected": "пЉ” {device_alias}",
  "tooltip-format": "{controller_alias}\t{controller_address}",
  "tooltip-format-connected": "{device_enumerate}",
  "tooltip-format-enumerate-connected": "пЉ” {device_alias}",
  "on-click": "blueman-manager"
},
  "pulseaudio#microphone": {
    "format": "{format_source}",
    "format-source": "п„°",
    "format-source-muted": "п„±",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
    "on-scroll-up": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SOURCE@ 5%+",
    "on-scroll-down": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SOURCE@ 5%-",
    "tooltip": true,
    "tooltip-format": "п„° at {volume}%"
  },

  "backlight": {
    "device": "intel_backlight",
    "format": "у°ѓћ {percent}%",
    "on-scroll-up": "brightnessctl set +5%",
    "on-scroll-down": "brightnessctl set 5%-"
  },

  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "у°‚„ {capacity}%",
    "format-plugged": "п‡¦ {capacity}%",
    "format-alt": "{icon} {capacity}%",
    "format-icons": [
      "у°Ѓє", "у°Ѓ»", "у°Ѓј", "у°ЃЅ", "у°Ѓѕ", "у°Ѓї", "у°‚Ђ", "у°‚Ѓ", "у°‚‚"
    ],
    "tooltip": true,
    "on-update": "~/.config/waybar/scripts/battery_notify.sh"
  },

  "network": {
    "format-wifi": "п‡«  {essid}",
    "format-ethernet": "пћ–  {ifname}",
    "format-disconnected": "п„§  Disconnected",
    "tooltip-format": "пћ– {ifname} via {gwaddr}",
    "tooltip-format-wifi": "п‡« {essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "пѓЃ {ifname} {ipaddr}/{cidr}",
    "tooltip-format-disconnected": "Disconnected",
    "on-click": "nm-connection-editor"
  },
"custom/power": {
  "format": "пЂ‘",
  "tooltip": false,
  "on-click": "wlogout"
},
  "tray": {
    "icon-size": 10,
    "spacing": 10
  }
}

